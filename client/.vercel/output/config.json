{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/conversations/?(?:/__data.json)?$",
			"dest": "/conversations"
		},
		{
			"src": "^/conversations/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/conversations/[id]"
		},
		{
			"src": "^/culture/?(?:/__data.json)?$",
			"dest": "/culture"
		},
		{
			"src": "^/culture/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/culture/[id]"
		},
		{
			"src": "^/flashcards/?(?:/__data.json)?$",
			"dest": "/flashcards"
		},
		{
			"src": "^/games/?(?:/__data.json)?$",
			"dest": "/games"
		},
		{
			"src": "^/games/daily-challenge/?(?:/__data.json)?$",
			"dest": "/games/daily-challenge"
		},
		{
			"src": "^/games/endless-runner/?(?:/__data.json)?$",
			"dest": "/games/endless-runner"
		},
		{
			"src": "^/games/picture-match/?(?:/__data.json)?$",
			"dest": "/games/picture-match"
		},
		{
			"src": "^/games/story-adventure/?(?:/__data.json)?$",
			"dest": "/games/story-adventure"
		},
		{
			"src": "^/games/story-adventure/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/games/story-adventure/[id]"
		},
		{
			"src": "^/games/whack-a-word/?(?:/__data.json)?$",
			"dest": "/games/whack-a-word"
		},
		{
			"src": "^/lessons/?(?:/__data.json)?$",
			"dest": "/lessons"
		},
		{
			"src": "^/lessons/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/lessons/[id]"
		},
		{
			"src": "^/listening/?(?:/__data.json)?$",
			"dest": "/listening"
		},
		{
			"src": "^/listening/quiz/?(?:/__data.json)?$",
			"dest": "/listening/quiz"
		},
		{
			"src": "^/practice/?(?:/__data.json)?$",
			"dest": "/practice"
		},
		{
			"src": "^/profile/?(?:/__data.json)?$",
			"dest": "/profile"
		},
		{
			"src": "^/quiz/?(?:/__data.json)?$",
			"dest": "/quiz"
		},
		{
			"src": "^/quiz/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/quiz/[id]"
		},
		{
			"src": "^/review/?(?:/__data.json)?$",
			"dest": "/review"
		},
		{
			"src": "^/review/quiz/?(?:/__data.json)?$",
			"dest": "/review/quiz"
		},
		{
			"src": "^/timed/?(?:/__data.json)?$",
			"dest": "/timed"
		},
		{
			"src": "^/timed/play/?(?:/__data.json)?$",
			"dest": "/timed/play"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}
[
  {
    "id": 1,
    "title": "Meeting Someone New",
    "description": "Practice introducing yourself and basic greetings with a new acquaintance.",
    "difficulty": "beginner",
    "xp_reward": 5,
    "turns": [
      {
        "type": "npc",
        "speaker": "Abebe",
        "romanized": "Selam! Endemin neh?",
        "amharic": "ሰላም! እንደምን ነህ?",
        "english": "Hello! How are you?",
        "audio_url": "/audio/conversations/convo-1-0.mp3"
      },
      {
        "type": "user",
        "prompt": "Greet Abebe back and say you're fine:",
        "options": [
          {
            "romanized": "Selam! Dehna negn, ameseginalehu.",
            "amharic": "ሰላም! ደህና ነኝ፣ አመሰግናለሁ።",
            "english": "Hello! I'm fine, thank you.",
            "feedback": "Perfect! A polite and complete greeting response.",
            "audio_url": "/audio/conversations/convo-1-user-1-0.mp3"
          },
          {
            "romanized": "Dehna negn.",
            "amharic": "ደህና ነኝ።",
            "english": "I'm fine.",
            "feedback": "Good, but adding 'selam' and 'ameseginalehu' would be more polite.",
            "audio_url": "/audio/conversations/convo-1-user-1-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Abebe",
        "romanized": "Simih man new?",
        "amharic": "ስምህ ማን ነው?",
        "english": "What is your name?",
        "audio_url": "/audio/conversations/convo-1-1.mp3"
      },
      {
        "type": "user",
        "prompt": "Tell Abebe your name:",
        "options": [
          {
            "romanized": "Sime [your name] new. Yante sine man new?",
            "amharic": "ስሜ [ስምህ] ነው። የአንተ ስም ማን ነው?",
            "english": "My name is [your name]. What is your name?",
            "feedback": "Excellent! Introducing yourself and asking their name back shows good conversation skills.",
            "audio_url": "/audio/conversations/convo-1-user-3-0.mp3"
          },
          {
            "romanized": "Sime [your name] new.",
            "amharic": "ስሜ [ስምህ] ነው።",
            "english": "My name is [your name].",
            "feedback": "Good! You can also ask 'Yante sine man new?' to keep the conversation going.",
            "audio_url": "/audio/conversations/convo-1-user-3-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Abebe",
        "romanized": "Destachihu! Ke yet ager neh?",
        "amharic": "ደስታቺሁ! ከየት አገር ነህ?",
        "english": "Nice to meet you! Where are you from?",
        "audio_url": "/audio/conversations/convo-1-2.mp3"
      },
      {
        "type": "user",
        "prompt": "Tell Abebe where you're from:",
        "options": [
          {
            "romanized": "Ke Amerika negn. Ante ke yet neh?",
            "amharic": "ከአሜሪካ ነኝ። አንተ ከየት ነህ?",
            "english": "I'm from America. Where are you from?",
            "feedback": "Great! Sharing your origin and asking about theirs builds rapport.",
            "audio_url": "/audio/conversations/convo-1-user-5-0.mp3"
          },
          {
            "romanized": "Ke Amerika negn.",
            "amharic": "ከአሜሪካ ነኝ።",
            "english": "I'm from America.",
            "feedback": "Good answer! Try asking about their background too.",
            "audio_url": "/audio/conversations/convo-1-user-5-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Abebe",
        "romanized": "Ishi, melkam ken! Dehna hunu.",
        "amharic": "እሽ፣ መልካም ቀን! ደህና ሁኑ።",
        "english": "Okay, have a nice day! Goodbye.",
        "audio_url": "/audio/conversations/convo-1-3.mp3"
      },
      {
        "type": "user",
        "prompt": "Say goodbye to Abebe:",
        "options": [
          {
            "romanized": "Dehna hunu! Ke melkam ken.",
            "amharic": "ደህና ሁኑ! ከመልካም ቀን።",
            "english": "Goodbye! Have a nice day.",
            "feedback": "A warm and proper farewell!",
            "audio_url": "/audio/conversations/convo-1-user-7-0.mp3"
          },
          {
            "romanized": "Ciao!",
            "amharic": "ጧዎ!",
            "english": "Bye!",
            "feedback": "Ciao is widely used in Ethiopia (from Italian influence), but 'Dehna hunu' is more traditional.",
            "audio_url": "/audio/conversations/convo-1-user-7-1.mp3"
          }
        ]
      }
    ]
  },
  {
    "id": 2,
    "title": "At the Coffee Shop",
    "description": "Order Ethiopian coffee and chat with the barista.",
    "difficulty": "beginner",
    "xp_reward": 5,
    "turns": [
      {
        "type": "npc",
        "speaker": "Barista",
        "romanized": "Selam! Min liteTu?",
        "amharic": "ሰላም! ምን ሊጠጡ?",
        "english": "Hello! What would you like to drink?",
        "audio_url": "/audio/conversations/convo-2-0.mp3"
      },
      {
        "type": "user",
        "prompt": "Order a coffee:",
        "options": [
          {
            "romanized": "Buna ifeligalehu, ibakish.",
            "amharic": "ቡና እፈልጋለሁ፣ እባክሽ።",
            "english": "I'd like coffee, please.",
            "feedback": "Perfect! Polite and clear. 'Ibakish' (please, to a female) shows good manners.",
            "audio_url": "/audio/conversations/convo-2-user-1-0.mp3"
          },
          {
            "romanized": "And buna isT'ign.",
            "amharic": "አንድ ቡና እስጥኝ።",
            "english": "Give me one coffee.",
            "feedback": "Direct but works! Adding 'ibakish/ibakih' (please) makes it friendlier.",
            "audio_url": "/audio/conversations/convo-2-user-1-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Barista",
        "romanized": "Ishi! Ke shukor gar?",
        "amharic": "እሽ! ከሽኩር ጋር?",
        "english": "Okay! With sugar?",
        "audio_url": "/audio/conversations/convo-2-1.mp3"
      },
      {
        "type": "user",
        "prompt": "Tell the barista about sugar preference:",
        "options": [
          {
            "romanized": "Awo, tinnish shukor.",
            "amharic": "አዎ፣ ትንሽ ሽኩር።",
            "english": "Yes, a little sugar.",
            "feedback": "Good! 'Tinnish' (a little) is very useful for modifying requests.",
            "audio_url": "/audio/conversations/convo-2-user-3-0.mp3"
          },
          {
            "romanized": "Yelam, yalem shukor.",
            "amharic": "የለም፣ ያለም ሽኩር።",
            "english": "No, without sugar.",
            "feedback": "Clear preference! 'Yalem' means 'without' - very handy vocabulary.",
            "audio_url": "/audio/conversations/convo-2-user-3-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Barista",
        "romanized": "Ishi, betam t'iru buna new. Sint birr yihonal?",
        "amharic": "እሽ፣ በጣም ጥሩ ቡና ነው። ስንት ብር ይሆናል?",
        "english": "Okay, it's very good coffee. How much birr will it be?",
        "audio_url": "/audio/conversations/convo-2-2.mp3"
      },
      {
        "type": "user",
        "prompt": "Respond about the price:",
        "options": [
          {
            "romanized": "Sint new? Ibakish.",
            "amharic": "ስንት ነው? እባክሽ።",
            "english": "How much is it? Please.",
            "feedback": "Smart! Always good to confirm the price before paying.",
            "audio_url": "/audio/conversations/convo-2-user-5-0.mp3"
          },
          {
            "romanized": "Ishi, ameseginalehu!",
            "amharic": "እሽ፣ አመሰግናለሁ!",
            "english": "Okay, thank you!",
            "feedback": "Friendly response! 'Ameseginalehu' is an important phrase to know.",
            "audio_url": "/audio/conversations/convo-2-user-5-1.mp3"
          }
        ]
      }
    ]
  },
  {
    "id": 3,
    "title": "Market Shopping",
    "description": "Practice bargaining and buying items at the local market.",
    "difficulty": "intermediate",
    "xp_reward": 5,
    "turns": [
      {
        "type": "npc",
        "speaker": "Vendor",
        "romanized": "Na! Na! Betam t'iru neger alle!",
        "amharic": "ና! ና! በጣም ጥሩ ነገር አለ!",
        "english": "Come! Come! There are very nice things!",
        "audio_url": "/audio/conversations/convo-3-0.mp3"
      },
      {
        "type": "user",
        "prompt": "Ask the vendor about prices:",
        "options": [
          {
            "romanized": "Yihe sint new?",
            "amharic": "ይሄ ስንት ነው?",
            "english": "How much is this?",
            "feedback": "The essential market phrase! 'Yihe' (this) + 'sint' (how much) + 'new' (is).",
            "audio_url": "/audio/conversations/convo-3-user-1-0.mp3"
          },
          {
            "romanized": "Min min aleh?",
            "amharic": "ምን ምን አለህ?",
            "english": "What do you have?",
            "feedback": "A good opener to browse what's available.",
            "audio_url": "/audio/conversations/convo-3-user-1-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Vendor",
        "romanized": "Yihe meato birr new.",
        "amharic": "ይሄ ሜአቶ ብር ነው።",
        "english": "This is 100 birr.",
        "audio_url": "/audio/conversations/convo-3-1.mp3"
      },
      {
        "type": "user",
        "prompt": "Try to bargain:",
        "options": [
          {
            "romanized": "Betam wid new! Hamsa birr yihonal?",
            "amharic": "በጣም ውድ ነው! ሐምሳ ብር ይሆናል?",
            "english": "It's too expensive! Would 50 birr work?",
            "feedback": "Classic bargaining! Starting at half price is a common strategy. 'Wid' (expensive) is essential market vocabulary.",
            "audio_url": "/audio/conversations/convo-3-user-3-0.mp3"
          },
          {
            "romanized": "Ishi, meato birr.",
            "amharic": "እሽ፣ ሜአቶ ብር።",
            "english": "Okay, 100 birr.",
            "feedback": "Accepting the first price is very unusual in Ethiopian markets! Try bargaining next time.",
            "audio_url": "/audio/conversations/convo-3-user-3-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Vendor",
        "romanized": "Ayi! Sebat birr yibelu, yihe t'iru neger new!",
        "amharic": "አይ! ሰባ ብር ይበሉ፣ ይሄ ጥሩ ነገር ነው!",
        "english": "No! They say 70 birr, this is a quality item!",
        "audio_url": "/audio/conversations/convo-3-2.mp3"
      },
      {
        "type": "user",
        "prompt": "Make a counter offer:",
        "options": [
          {
            "romanized": "Silsa birr, yihe yemecher'esha zega new.",
            "amharic": "ስልሳ ብር፣ ይሄ የመጨረሻ ዘጋ ነው።",
            "english": "60 birr, this is my final offer.",
            "feedback": "Well negotiated! Meeting in the middle is the art of Ethiopian bargaining.",
            "audio_url": "/audio/conversations/convo-3-user-5-0.mp3"
          },
          {
            "romanized": "Ishi, sebat birr.",
            "amharic": "እሽ፣ ሰባ ብር።",
            "english": "Okay, 70 birr.",
            "feedback": "Fair enough! You got a decent price down from 100.",
            "audio_url": "/audio/conversations/convo-3-user-5-1.mp3"
          }
        ]
      }
    ]
  },
  {
    "id": 4,
    "title": "Asking Directions",
    "description": "Learn to ask for and understand directions to find your way around.",
    "difficulty": "intermediate",
    "xp_reward": 5,
    "turns": [
      {
        "type": "npc",
        "speaker": "You (thinking)",
        "romanized": "Yihe bet migib yet new?",
        "amharic": "ይሄ በት ምግብ የት ነው?",
        "english": "(You're looking for a restaurant...)",
        "audio_url": "/audio/conversations/convo-4-0.mp3"
      },
      {
        "type": "user",
        "prompt": "Ask a passerby for directions:",
        "options": [
          {
            "romanized": "Yikerta, bet migib yet endemaign yinegerugn?",
            "amharic": "ይቀርታ፣ በት ምግብ የት እንደማኝ ይነገሩኝ?",
            "english": "Excuse me, could you tell me where a restaurant is?",
            "feedback": "Very polite! 'Yikerta' (excuse me) is the perfect way to approach a stranger for help.",
            "audio_url": "/audio/conversations/convo-4-user-1-0.mp3"
          },
          {
            "romanized": "Bet migib yetegnyaleh?",
            "amharic": "በት ምግብ የተኛለህ?",
            "english": "Do you know where a restaurant is?",
            "feedback": "Direct but works. Adding 'yikerta' at the start would be more polite.",
            "audio_url": "/audio/conversations/convo-4-user-1-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Passerby",
        "romanized": "Awo! Ke'zzih bequt'a wede feqad hid, kezia wede gra tikelefaleh.",
        "amharic": "አዎ! ከዕዚህ በቁጥአ ወደ ፈቃድ ሂድ፣ ከዚያ ወደ ግራ ትከለፋለህ።",
        "english": "Yes! Go straight ahead from here, then you'll turn left.",
        "audio_url": "/audio/conversations/convo-4-1.mp3"
      },
      {
        "type": "user",
        "prompt": "Confirm you understand:",
        "options": [
          {
            "romanized": "Ameseginalehu! Ruk new?",
            "amharic": "አመሰግናለሁ! ሩቅ ነው?",
            "english": "Thank you! Is it far?",
            "feedback": "Great follow-up question! 'Ruk' (far) is a very practical word.",
            "audio_url": "/audio/conversations/convo-4-user-3-0.mp3"
          },
          {
            "romanized": "Ameseginalehu betam!",
            "amharic": "አመሰግናለሁ በጣም!",
            "english": "Thank you very much!",
            "feedback": "Polite and warm! 'Betam' (very much) adds emphasis to your gratitude.",
            "audio_url": "/audio/conversations/convo-4-user-3-1.mp3"
          }
        ]
      },
      {
        "type": "npc",
        "speaker": "Passerby",
        "romanized": "Ayrukm, amist deqiqa yihedal. Melkam megib!",
        "amharic": "አይሩቅም፣ አምስት ደቂቃ ይሄዳል። መልካም መግብ!",
        "english": "It's not far, about 5 minutes. Enjoy your meal!",
        "audio_url": "/audio/conversations/convo-4-2.mp3"
      },
      {
        "type": "user",
        "prompt": "Thank them and say goodbye:",
        "options": [
          {
            "romanized": "Ameseginalehu! Dehna hunu.",
            "amharic": "አመሰግናለሁ! ደህና ሁኑ።",
            "english": "Thank you! Goodbye.",
            "feedback": "A warm and proper farewell. Well done!",
            "audio_url": "/audio/conversations/convo-4-user-5-0.mp3"
          },
          {
            "romanized": "Igziabher yistilign.",
            "amharic": "እግዚአብሄር ይስጥልኝ።",
            "english": "May God reward you.",
            "feedback": "A beautiful traditional blessing often said to thank someone for their help.",
            "audio_url": "/audio/conversations/convo-4-user-5-1.mp3"
          }
        ]
      }
    ]
  },
  {
    "id": 5,
    "title": "At the Restaurant",
    "description": "Order food and navigate a dining experience in Amharic.",
    "difficulty": "intermediate",
    "xp_reward": 5,
    "turns": [
      {
        "type": "npc",
        "speaker": "Waiter",
        "romanized": "Enkhwan dehna meT'u! Min yagebual?",
        "amharic": "እንዉን ደህና መጡ! ምን ያገቡአል?",
        "english": "Welcome! What can I serve you?",
        "audio_url": "/audio/conversations/convo-5-0.mp3"
      },
      {
        "type": "user",
        "prompt": "Ask about the menu:",
        "options": [
          {
            "romanized": "Menu aleh? Min tmelkitaleh?",
            "amharic": "ሜኑ አለህ? ምን ትመልክታለህ?",
            "english": "Do you have a menu? What do you recommend?",
            "feedback": "Smart approach! Asking for recommendations shows cultural openness.",
            "audio_url": "/audio/conversations/convo-5-user-1-0.mp3"
